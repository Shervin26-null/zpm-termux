local ZPM={}

ZPM.name="Zenith Package Matrix"
ZPM.short="zpm"
ZPM.version="0.0.1-alpha"

local T={}

T.reset="\27[0m"
T.red="\27[31m"
T.green="\27[32m"
T.yellow="\27[33m"
T.blue="\27[34m"
T.magenta="\27[35m"
T.cyan="\27[36m"
T.white="\27[37m"
T.bold="\27[1m"

function T.paint(v,c)
    return c..v..T.reset
end

function T.info(v)
    print(
        T.paint(
            ":: ",
            T.blue
        )
        ..
        v
    )
end

function T.ok(v)
    print(
        T.paint(
            "[OK] ",
            T.green
        )
        ..
        v
    )
end

function T.warn(v)
    print(
        T.paint(
            "[WARN] ",
            T.yellow
        )
        ..
        v
    )
end

function T.fail(v)
    io.stderr:write(
        T.paint(
            "[ERROR] ",
            T.red
        )
        ..
        v
        ..
        "\n"
    )
end

function T.step(v)
    print(
        T.paint(
            "=> ",
            T.cyan
        )
        ..
        v
    )
end

local LOG={}

LOG.enabled=false
LOG.file=nil

function LOG.init(path)

    LOG.file=path

end

function LOG.write(msg)

    if not LOG.enabled then
        return
    end

    if not LOG.file then
        return
    end

    local f=
        io.open(
            LOG.file,
            "a"
        )

    if f then
        f:write(
            os.date()
            ..
            " "
            ..
            msg
            ..
            "\n"
        )
        f:close()
    end

end

function LOG.debug(msg)

    LOG.write(
        "[debug] "
        ..
        msg
    )

end


local DEBUG=false

local function debug(msg)

    LOG.debug(
        msg
    )

    if DEBUG then

        print(
            T.paint(
                "[debug] ",
                T.magenta
            )
            ..
            msg
        )

    end

end


local function exec(cmd)

    debug(
        cmd
    )

    return os.execute(
        cmd
    )

end


local function output(cmd)

    local p=
        io.popen(
            cmd
        )

    if not p then
        return ""
    end

    local r=
        p:read(
            "*a"
        )

    p:close()

    return r

end


local function exists(path)

    local r=
        os.execute(
            "test -e "
            ..
            path
        )

    return r==true
    or r==0

end


local function command_exists(cmd)

    local r=
        os.execute(
            "command -v "
            ..
            cmd
            ..
            " >/dev/null 2>&1"
        )

    return r==true
    or r==0

end


local function mkdir(path)

    exec(
        "mkdir -p "
        ..
        path
    )

end


local function read_file(path)

    local f=
        io.open(
            path,
            "r"
        )

    if not f then
        return nil
    end

    local data=
        f:read(
            "*a"
        )

    f:close()

    return data

end


local function write_file(path,data)

    local f=
        io.open(
            path,
            "w"
        )

    if not f then
        return false
    end

    f:write(
        data
    )

    f:close()

    return true

end


local function append_file(path,data)

    local f=
        io.open(
            path,
            "a"
        )

    if not f then
        return false
    end

    f:write(
        data
    )

    f:close()

    return true

end


local function trim(v)

    return (
        v:gsub(
            "^%s+",
            ""
        )
        :gsub(
            "%s+$",
            ""
        )
    )

end


local function split(v,sep)

    local out={}

    for x in string.gmatch(
        v,
        "([^"..sep.."]+)"
    ) do

        table.insert(
            out,
            trim(x)
        )

    end

    return out

end
local function join(list,sep)

    local out=""

    for i,v in ipairs(list) do

        out=out..v

        if i<#list then
            out=out..sep
        end

    end

    return out

end


local function contains(list,value)

    for _,v in ipairs(list) do

        if v==value then
            return true
        end

    end

    return false

end


local function remove_item(list,value)

    local out={}

    for _,v in ipairs(list) do

        if v~=value then
            table.insert(
                out,
                v
            )
        end

    end

    return out

end


local function map(list,fn)

    local out={}

    for i,v in ipairs(list) do

        out[i]=fn(v)

    end

    return out

end


local function count(list)

    local n=0

    for _ in ipairs(list) do
        n=n+1
    end

    return n

end


local function table_copy(t)

    local r={}

    for k,v in pairs(t) do
        r[k]=v
    end

    return r

end


local function file_exists(path)

    local f=
        io.open(
            path,
            "r"
        )

    if f then
        f:close()
        return true
    end

    return false

end


local function basename(path)

    return path:match(
        "([^/]+)$"
    )

end


local function dirname(path)

    return path:match(
        "(.+)/[^/]+$"
    )

end


local function version()

    return ZPM.short
        ..
        " "
        ..
        ZPM.version

end


local function header()

    print(
        version()
    )

end


local args=arg or {}

local CLI={}

CLI.command=nil
CLI.options={}
CLI.params={}


function CLI.parse()

    CLI.command=
        args[1]


    for i=2,#args do

        local a=
            args[i]

        if a:sub(
            1,
            2
        )=="--" then

            local k,v=
                a:match(
                    "^%-%-(.-)=(.*)"
                )

            if k then

                CLI.options[k]=v

            else

                CLI.options[
                    a:sub(3)
                ]=true

            end

        else

            table.insert(
                CLI.params,
                a
            )

        end

    end

end


function CLI.has(name)

    return CLI.options[name]
    ==true

end


function CLI.get(name)

    return CLI.options[name]

end


function CLI.first()

    return CLI.params[1]

end


CLI.parse()


