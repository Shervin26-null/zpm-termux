local TX={}

TX.packages={}
TX.action=nil


function TX.add(pkg)

    table.insert(
        TX.packages,
        pkg
    )

end


function TX.clear()

    TX.packages={}

end


function TX.show()

    if #TX.packages==0 then
        return
    end


    print()


    T.info(
        "Transaction summary"
    )


    for _,pkg in ipairs(
        TX.packages
    ) do

        print(
            "  "
            ..
            pkg
        )

    end


    print()

end



function TX.confirm()

    if not CONFIG.settings.confirm then
        return true
    end


    io.write(
        ":: Proceed? [Y/n] "
    )


    local r=
        io.read()


    if not r
    or r==""
    or r=="Y"
    or r=="y"
    then

        return true

    end


    return false

end



function TX.start(action)

    TX.action=action

    TX.clear()

end



function TX.finish()

    TX.clear()
    TX.action=nil

end



local function install_flow(pkgs)

    TX.start(
        "install"
    )


    for _,p in ipairs(pkgs) do

        TX.add(
            p
        )

    end


    TX.show()


    if not TX.confirm() then

        T.warn(
            "cancelled"
        )

        return

    end


    for i,p in ipairs(
        TX.packages
    ) do

        print(
            "("
            ..
            i
            ..
            "/"
            ..
            #TX.packages
            ..
            ") installing "
            ..
            p
            ..
            "..."
        )


        APT.install(
            p
        )


        DB.add(
            p
        )

    end


    T.ok(
        "Transaction complete"
    )


    TX.finish()

end



local function remove_flow(pkgs)

    TX.start(
        "remove"
    )


    for _,p in ipairs(pkgs) do

        TX.add(
            p
        )

    end


    TX.show()


    if not TX.confirm() then

        return

    end


    for i,p in ipairs(
        TX.packages
    ) do

        print(
            "("
            ..
            i
            ..
            "/"
            ..
            #TX.packages
            ..
            ") removing "
            ..
            p
        )


        APT.remove(
            p
        )


        DB.remove(
            p
        )

    end


    T.ok(
        "Removal complete"
    )


end



