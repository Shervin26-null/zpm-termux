local UPGRADE={}

UPGRADE.pending={}


function UPGRADE.scan()

    UPGRADE.pending={}

    local list=
        output(
            "apt list --upgradable 2>/dev/null"
        )

    for line in list:gmatch(
        "[^\n]+"
    ) do

        local pkg=
            line:match(
                "^([^/]+)/"
            )

        if pkg then

            table.insert(
                UPGRADE.pending,
                pkg
            )

        end

    end

    return UPGRADE.pending

end



function UPGRADE.show()

    local list=
        UPGRADE.scan()


    if #list==0 then

        T.ok(
            "system is up to date"
        )

        return

    end


    T.info(
        "available upgrades"
    )


    for _,p in ipairs(list) do

        print(
            "  "
            ..
            p
        )

    end

end



function UPGRADE.all()

    local list=
        UPGRADE.scan()


    if #list==0 then
        return
    end


    TX.start(
        "upgrade"
    )


    for _,p in ipairs(list) do

        TX.add(
            p
        )

    end


    TX.show()


    if not TX.confirm() then
        return
    end


    T.info(
        "upgrading system"
    )


    APT.upgrade()


    for _,p in ipairs(list) do

        HISTORY.add(
            "upgrade",
            p
        )

    end


    TX.finish()

end



function UPGRADE.one(pkg)

    if not pkg then

        T.fail(
            "missing package"
        )

        return

    end


    TX.start(
        "upgrade"
    )


    TX.add(
        pkg
    )


    TX.show()


    if not TX.confirm() then
        return
    end


    APT.install(
        pkg
    )


    HISTORY.add(
        "upgrade",
        pkg
    )


    TX.finish()

end



function UPGRADE.check()

    local list=
        UPGRADE.scan()


    return #list

end



