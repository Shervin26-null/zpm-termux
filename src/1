function CONFIG.load()

    if not file_exists(
        CONFIG.path
    ) then

        CONFIG.save()

        return

    end


    local data=
        read_file(
            CONFIG.path
        )


    if not data then
        return
    end


    for k,v in data:gmatch(
        "([^=]+)=([^\n]+)"
    ) do

        CONFIG.settings[
            trim(k)
        ]=
            trim(v)

    end

end



function CONFIG.save()

    local out=""

    for k,v in pairs(
        CONFIG.settings
    ) do

        out=
            out
            ..
            k
            ..
            "="
            ..
            tostring(v)
            ..
            "\n"

    end


    write_file(
        CONFIG.path,
        out
    )

end



local DB={}


DB.packages={}



function DB.load()

    DB.packages={}


    local data=
        read_file(
            CONFIG.db
        )


    if not data then
        return
    end


    for line in data:gmatch(
        "[^\n]+"
    ) do

        table.insert(
            DB.packages,
            line
        )

    end

end



function DB.save()

    write_file(
        CONFIG.db,
        join(
            DB.packages,
            "\n"
        )
    )

end



function DB.has(pkg)

    return contains(
        DB.packages,
        pkg
    )

end



function DB.add(pkg)

    if DB.has(
        pkg
    ) then
        return
    end


    table.insert(
        DB.packages,
        pkg
    )


    DB.save()

end



function DB.remove(pkg)

    DB.packages=
        remove_item(
            DB.packages,
            pkg
        )


    DB.save()

end



function DB.list()

    return DB.packages

end



