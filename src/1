function QUERY.owned(path)

    if not path then

        T.fail(
            "missing path"
        )

        return

    end


    if not exists(path) then

        T.fail(
            "file not found: "
            ..
            path
        )

        return

    end


    local result=
        output(
            "dpkg -S "
            ..
            path
            ..
            " 2>/dev/null"
        )


    result=
        trim(result)


    if result=="" then

        T.warn(
            "no owner found"
        )

        return

    end


    T.info(
        "owned by"
    )


    print(
        "  "
        ..
        result
    )

end



function QUERY.verify(pkg)

    if not pkg then

        T.fail(
            "missing package"
        )

        return

    end


    T.info(
        "verifying "
        ..
        pkg
    )


    local r=
        exec(
            "dpkg -V "
            ..
            pkg
            ..
            " >/dev/null 2>&1"
        )


    if r==0 then

        T.ok(
