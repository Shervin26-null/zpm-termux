local PKG={}

PKG.cache=
    SYS.cache
    ..
    "/packages"


mkdir(
    PKG.cache
)



function PKG.file(name)

    return PKG.cache
        ..
        "/"
        ..
        name

end



function PKG.hash(file)

    if command_exists(
        "sha256sum"
    ) then

        return trim(
            output(
                "sha256sum "
                ..
                file
            )
        )

    end


    return nil

end



function PKG.verify_file(file)

    if not file_exists(
        file
    ) then

        T.fail(
            "file missing"
        )

        return false

    end


    T.info(
        "checking package integrity"
    )


    if command_exists(
        "dpkg"
    ) then

        local r=
            exec(
                "dpkg-deb -I "
                ..
                file
                ..
                " >/dev/null 2>&1"
            )


        if r==0 then

            T.ok(
                "package valid"
            )

            return true

        end

    end


    T.fail(
        "invalid package"
    )

    return false

end



function PKG.install_deb(file)

    if not PKG.verify_file(
        file
    ) then

        return

    end


    T.info(
        "installing "
        ..
        basename(file)
    )


    APT.deb(
        file
    )

end



function PKG.download(pkg,method)

    local cmd=nil


    if method=="curl"
    and command_exists("curl")
    then

        cmd=
            "curl -LO "

    elseif method=="wget"
    and command_exists("wget")
    then

        cmd=
            "wget "

    end



    if not cmd then

        if command_exists(
            "apt"
        ) then

            return APT.download(
                pkg
            )

        end

    end



    T.info(
        "downloading "
        ..
        pkg
    )


    return exec(
        cmd
        ..
        pkg
    )

end



